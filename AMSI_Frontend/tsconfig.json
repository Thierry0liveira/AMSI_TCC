{
	"compilerOptions": {
		"target": "ESNext",
		"useDefineForClassFields": true,
		"lib": ["DOM", "ESNext"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowJs": true,
		"jsx": "react-jsx",
		"noEmit": true,
		"forceConsistentCasingInFileNames": false
	},
	"include": ["src"]
}
